# Cyber Defense System — FastAPI + PostgreSQL + React

# Session / auth
CDS_SECRET_KEY=generate-a-long-random-secret
CDS_ADMIN_USER=admin
CDS_ADMIN_PASSWORD=changeme
CDS_ANALYST_USER=analyst
CDS_ANALYST_PASSWORD=analyst123
CDS_VIEWER_USER=viewer
CDS_VIEWER_PASSWORD=viewer123

# PostgreSQL (primary persistence)
CDS_DATABASE_URL=postgresql://cds:cds_secret@localhost:5432/cyber_defense

# SQLite fallback when CDS_DATABASE_URL is empty (local tests only)
CDS_DB_PATH=

# Runtime
CDS_DEMO_MODE=false
CDS_ML_SHADOW_MODE=true
CDS_ML_CANARY=false
CDS_BIND_HOST=127.0.0.1
CDS_PORT=8080
CDS_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8080
CDS_FIREWALL_ENABLED=true
